# Dave IT Guy — RAG Pipeline Stack
# Generated by: dave-it-guy deploy rag
# Docs: https://github.com/NeuroGamingLab/dave-it-guy

version: "3.8"

services:
  qdrant:
    image: qdrant/qdrant:latest
    container_name: dave-it-guy-qdrant
    restart: unless-stopped
    volumes:
      - qdrant_data:/qdrant/storage
    ports:
      - "6333:6333"
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:6333/healthz || exit 1"]
      interval: 5s
      timeout: 10s
      retries: 10
      start_period: 15s
    networks:
      - dave-it-guy

  embeddings:
    image: ghcr.io/huggingface/text-embeddings-inference:latest
    container_name: dave-it-guy-embeddings
    restart: unless-stopped
    ports:
      - "8081:80"
    environment:
      - MODEL_ID={{ embedding_model | default('BAAI/bge-small-en-v1.5') }}
    volumes:
      - embeddings_cache:/data
    networks:
      - dave-it-guy

  rag-api:
    image: python:3.11-slim
    container_name: dave-it-guy-rag-api
    restart: unless-stopped
    ports:
      - "{{ gateway_port | default('8080') }}:8080"
    environment:
      - QDRANT_URL=http://qdrant:6333
      - EMBEDDINGS_URL=http://embeddings:80
      - COLLECTION_NAME={{ collection_name | default('documents') }}
      - API_PORT=8080
{% for key, value in env_vars.items() %}
      - {{ key }}={{ value }}
{% endfor %}
    depends_on:
      qdrant:
        condition: service_healthy
      embeddings:
        condition: service_started
    networks:
      - dave-it-guy

volumes:
  qdrant_data:
  embeddings_cache:

networks:
  dave-it-guy:
    driver: bridge
