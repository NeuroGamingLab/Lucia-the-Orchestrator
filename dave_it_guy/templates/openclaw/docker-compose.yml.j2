# Dave IT Guy — OpenClaw Stack
# Generated by: dave-it-guy deploy openclaw
# Docs: https://github.com/NeuroGamingLab/dave-it-guy

services:
  # One-off: fix volume permissions so node user can write (canvas, cron, etc.)
  openclaw-init:
    image: alpine
    volumes:
      - openclaw_data:/data
    command: sh -c "chown -R 1000:1000 /data 2>/dev/null || true"
    user: root
    restart: "no"

  # One-off: install Python deps (duckduckgo-search, qdrant-client, sentence-transformers) into volume; OpenClaw image has no pip
  openclaw-pip-deps:
    image: python:3.11-slim
    user: root
    volumes:
      - openclaw_data:/data
    command:
      - sh
      - -c
      - |
        set -e
        mkdir -p /data/site-packages
        for i in 1 2 3; do
          echo "[pip-deps] Attempt $$i/3: installing workspace deps..."
          if pip install --target=/data/site-packages --no-cache-dir duckduckgo-search qdrant-client sentence-transformers httpx; then
            break
          fi
          if [ $$i -eq 3 ]; then echo "[pip-deps] All retries failed"; exit 1; fi
          echo "[pip-deps] Retrying in 15s..."
          sleep 15
        done
        chown -R 1000:1000 /data/site-packages
        echo "[pip-deps] Verifying qdrant_client..."
        python3 -c "import sys; sys.path.insert(0, '/data/site-packages'); import qdrant_client; print('qdrant_client OK')" || exit 1
        echo "workspace deps installed (duckduckgo-search, qdrant-client, sentence-transformers, httpx)"
    restart: "no"
    depends_on:
      openclaw-init:
        condition: service_completed_successfully
    networks:
      - dave-it-guy

  openclaw:
    image: ghcr.io/openclaw/openclaw:latest
    container_name: dave-it-guy-openclaw
    restart: unless-stopped
    ports:
      - "{{ gateway_port | default('18789') }}:18789"
    volumes:
      - openclaw_data:/home/node/.openclaw
      - ./workspace:/home/node/.openclaw/workspace
      - ./config:/app/config
    env_file:
      - .env
    environment:
      - OPENCLAW_HOST=0.0.0.0
      - OPENCLAW_CONFIG_PATH=/app/config/openclaw.json
      - OLLAMA_HOST=http://ollama:11434
      - QDRANT_URL={{ qdrant_primary_url }}
      - QDRANT_FALLBACK_URL={{ qdrant_fallback_url }}
      - PYTHONPATH=/home/node/.openclaw/site-packages
      - MASTERCLAW_URL=http://masterclaw:8090
    depends_on:
      openclaw-init:
        condition: service_completed_successfully
      openclaw-pip-deps:
        condition: service_completed_successfully
      ollama:
        condition: service_started
      qdrant:
        condition: service_healthy
    networks:
      - dave-it-guy

  # One-off: install memory-qdrant skill via GitHub tarball (Alpine has curl; no TTY needed)
  openclaw-skill-qdrant:
    image: alpine:3.19
    user: root
    volumes:
      - openclaw_data:/data
    command:
      - sh
      - -c
      - |
        apk add --no-cache curl
        SKILLS_DIR=/data/skills
        TARGET=$$SKILLS_DIR/memory-qdrant
        if [ -d "$$TARGET" ]; then echo 'memory-qdrant already installed'; exit 0; fi
        mkdir -p "$$SKILLS_DIR"
        (curl -sLf https://github.com/zuiho-kai/openclaw-memory-qdrant/archive/refs/heads/master.tar.gz | tar xz -C /tmp) && \
        mv /tmp/openclaw-memory-qdrant-master "$$TARGET" && chown -R 1000:1000 "$$SKILLS_DIR" && echo 'memory-qdrant installed' || exit 1
    depends_on:
      openclaw:
        condition: service_started
    restart: "no"
    networks:
      - dave-it-guy

  ollama:
    image: ollama/ollama:latest
    container_name: dave-it-guy-ollama
    restart: unless-stopped
{% if ollama_port is not none %}
    ports:
      - "{{ ollama_port }}:11434"
{% endif %}
{% if gpu %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
{% endif %}
    volumes:
      - ollama_models:/root/.ollama
    networks:
      - dave-it-guy

  qdrant:
    image: qdrant/qdrant:latest
    container_name: dave-it-guy-qdrant
    restart: unless-stopped
    ports:
      - "6333:6333"
    volumes:
      - qdrant_data:/qdrant/storage
    healthcheck:
      # Qdrant image has no curl/wget; use TCP check (bash /dev/tcp)
      test: ["CMD-SHELL", "bash -c ':> /dev/tcp/127.0.0.1/6333' || exit 1"]
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 15s
    networks:
      - dave-it-guy

  # MasterClaw — orchestrator: API to spin off sub-agent (worker) containers using Ollama
  masterclaw:
    build: ./masterclaw
    image: dave-it-guy-masterclaw:latest
    container_name: dave-it-guy-masterclaw
    restart: unless-stopped
    ports:
      - "{{ masterclaw_port | default('8090') }}:8090"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - subagent_tasks:/tasks
    environment:
      - OLLAMA_HOST=http://ollama:11434
      - MASTERCLAW_WORKER_IMAGE=dave-it-guy-masterclaw:latest
      - MASTERCLAW_NETWORK={{ compose_project_name }}_dave-it-guy
      - MASTERCLAW_TASKS_ROOT=/tasks
      - MASTERCLAW_TASKS_VOLUME={{ compose_project_name }}_subagent_tasks
      - MASTERCLAW_DEPLOY_PATH={{ deploy_path }}
      - MASTERCLAW_OPENCLAW_VOLUME={{ compose_project_name }}_openclaw_data
      - MASTERCLAW_OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
      - QDRANT_URL={{ qdrant_primary_url }}
      - QDRANT_FALLBACK_URL={{ qdrant_fallback_url }}
    depends_on:
      ollama:
        condition: service_started
      qdrant:
        condition: service_healthy
    networks:
      - dave-it-guy

volumes:
  openclaw_data:
  ollama_models:
  qdrant_data:
  subagent_tasks:

networks:
  dave-it-guy:
    driver: bridge
