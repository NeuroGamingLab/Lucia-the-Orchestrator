# Dave IT Guy — Ollama Stack Configuration
# Copy to .env and fill in your values

# Optional: Models to pre-pull on startup (comma-separated)
# DAVE_IT_GUY_MODELS=llama3.1:8b,mistral:7b,nomic-embed-text

# Optional: GPU support (true/false)
# DAVE_IT_GUY_GPU=false

# Optional: Open WebUI port (default: 3000)
# DAVE_IT_GUY_PORT=3000
