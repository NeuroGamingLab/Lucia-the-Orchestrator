# KrakenWhip — OpenClaw Stack Configuration
# Copy to .env and fill in your values

# Required: Your API key for the LLM provider
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: OpenAI key (for GPT models)
# OPENAI_API_KEY=sk-xxxxx

# Optional: Gateway authentication token
# KRAKENWHIP_GATEWAY_TOKEN=your-secret-token

# Optional: Models to pre-pull on startup (comma-separated)
# KRAKENWHIP_MODELS=llama3.1:8b,mistral:7b

# Optional: GPU support (true/false)
# KRAKENWHIP_GPU=false
