# KrakenWhip — Ollama Stack Configuration
# Copy to .env and fill in your values

# Optional: Models to pre-pull on startup (comma-separated)
# KRAKENWHIP_MODELS=llama3.1:8b,mistral:7b,nomic-embed-text

# Optional: GPU support (true/false)
# KRAKENWHIP_GPU=false

# Optional: Open WebUI port (default: 3000)
# KRAKENWHIP_PORT=3000
